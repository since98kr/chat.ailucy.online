{
  "name": "chat-ailucy-online-v2",
  "private": true,
  "version": "0.8.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n web,api -c blue,magenta \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "vite --host 0.0.0.0",
    "dev:api": "tsx watch server/runtime.ts",
    "build": "npm run typecheck && npm run build:web && npm run build:api",
    "build:web": "vite build",
    "build:api": "tsup server/runtime.ts server/backup.ts server/preflight.ts --format esm --platform node --target node22 --out-dir dist-server --sourcemap",
    "typecheck": "tsc --noEmit --pretty false",
    "test": "vitest run && npm run test:bridge",
    "test:bridge": "node --test ops/letta-bridge/letta-bridge.nodecheck.mjs",
    "test:e2e": "playwright test",
    "test:e2e:auth": "playwright test --config playwright.auth.config.ts",
    "test:e2e:staging": "playwright test --config playwright.staging.config.ts",
    "backup": "node dist-server/backup.js create",
    "backup:verify": "node dist-server/backup.js verify",
    "preflight": "node dist-server/preflight.js",
    "preflight:strict": "node dist-server/preflight.js --strict",
    "preview": "vite preview --host 0.0.0.0",
    "start": "node dist-server/runtime.js",
    "start:api": "node dist-server/runtime.js"
  },
  "dependencies": {
    "@fastify/cors": "latest",
    "@fastify/multipart": "latest",
    "@fastify/static": "latest",
    "better-sqlite3": "latest",
    "fastify": "latest",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@playwright/test": "latest",
    "@types/better-sqlite3": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "concurrently": "latest",
    "tsx": "latest",
    "tsup": "latest",
    "typescript": "latest",
    "vite": "latest",
    "vitest": "latest"
  }
}
