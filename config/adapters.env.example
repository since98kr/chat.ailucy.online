# chat.ailucy.online V2 runtime and staging environment example
# Never commit real API keys, access tokens, or personal email addresses.

CHAT_ENVIRONMENT=staging
CHAT_PUBLIC_ORIGIN=https://chat-staging.ailucy.online
CHAT_ALLOWED_ORIGIN=https://chat-staging.ailucy.online

# Recommended for a private browser service behind Cloudflare Access.
CHAT_AUTH_MODE=cloudflare
CHAT_ALLOWED_EMAILS=your-account@example.com
CHAT_ACCESS_TOKEN=

CHAT_RATE_LIMIT_GENERAL=300
CHAT_RATE_LIMIT_CHAT=30
CHAT_RATE_LIMIT_UPLOAD=60
CHAT_MAX_UPLOAD_BYTES=52428800
CHAT_MAX_GENERATED_ARTIFACT_BYTES=52428800
CHAT_BACKUP_ROOT=/data/backups
CHAT_BACKUP_RETENTION=10
CHAT_PREFLIGHT_MIN_FREE_BYTES=2147483648

# Leave BASE_URL empty only for local development or non-strict diagnosis.
# Strict staging deployment requires both adapters to be configured and healthy.
LETTA_BASE_URL=
LETTA_CHAT_PATH=/v1/chat/stream
LETTA_HEALTH_PATH=/health
LETTA_AGENT_ID=[Letta] Lucy
LETTA_API_KEY=
LETTA_TIMEOUT_MS=10000
LETTA_PROTOCOL=native
LETTA_MODEL_MAP_JSON=
LETTA_MAX_ARTIFACT_BYTES=10485760
LETTA_MAX_ARTIFACT_TOTAL_BYTES=20971520
# Text documents are injected into the current Letta turn. Binary input fails unless this capability is explicitly enabled.
LETTA_MAX_TEXT_ARTIFACT_BYTES=2097152
LETTA_NATIVE_BINARY_ARTIFACTS=false
LETTA_ARTIFACT_TOOL_ENABLED=false

# Hermes on the current home-server deployment exposes an OpenAI-compatible API.
HERMES_BASE_URL=http://hermes:8643
HERMES_CHAT_PATH=/v1/chat/completions
HERMES_HEALTH_PATH=/health
HERMES_AGENT_ID=
HERMES_API_KEY=
HERMES_TIMEOUT_MS=120000
HERMES_PROTOCOL=openai
# Optional JSON map from Chat V2 agent IDs to Hermes model IDs.
# Example: {"[Hermes] Lucy":"lucy","Xixi":"xixi","Lynn":"lynn","Gemma":"gemma"}
HERMES_MODEL_MAP_JSON=
HERMES_MAX_ARTIFACT_BYTES=10485760
HERMES_MAX_ARTIFACT_TOTAL_BYTES=20971520
# Enable only after the selected Hermes models are verified to accept OpenAI function tools.
HERMES_ARTIFACT_TOOL_ENABLED=false
# Optional host-side Docker network used when Hermes is reachable only by service DNS.
HERMES_DOCKER_NETWORK=hermes_default
