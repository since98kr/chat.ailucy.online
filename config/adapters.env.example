# Leave BASE_URL empty to use the deterministic development mock adapter.

LETTA_BASE_URL=
LETTA_CHAT_PATH=/v1/chat/stream
LETTA_HEALTH_PATH=/health
LETTA_AGENT_ID=[Letta] Lucy
LETTA_API_KEY=
LETTA_TIMEOUT_MS=10000

HERMES_BASE_URL=
HERMES_CHAT_PATH=/v1/chat/stream
HERMES_HEALTH_PATH=/health
HERMES_AGENT_ID=[Hermes] Lucy
HERMES_API_KEY=
HERMES_TIMEOUT_MS=10000

# Runtime security. Keep disabled only for localhost development and isolated staging.
# For chat.ailucy.online behind Cloudflare Access use:
# CHAT_AUTH_MODE=cloudflare
# CHAT_ALLOWED_EMAILS=your-account@example.com
CHAT_AUTH_MODE=disabled
CHAT_ALLOWED_EMAILS=
CHAT_ACCESS_TOKEN=
CHAT_PUBLIC_ORIGIN=
CHAT_ALLOWED_ORIGIN=
CHAT_RATE_LIMIT_GENERAL=300
CHAT_RATE_LIMIT_CHAT=30
CHAT_RATE_LIMIT_UPLOAD=60

CHAT_MAX_UPLOAD_BYTES=52428800
CHAT_BACKUP_ROOT=/data/backups
CHAT_BACKUP_RETENTION=10
